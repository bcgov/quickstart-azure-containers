{
  "author": "BC Government Forestry Suite of Applications Starter Template",
  "license": "Apache-2.0",
  "main": "index.js",
  "scripts": {
    "prisma-generate": "prisma generate",
    "prebuild": "rimraf dist",
    "build": "prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "deploy": "npm ci --ignore-scripts --no-update-notifier && npm run build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --require ./dist/instrumentation.js dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:staged": "./node_modules/.bin/lint-staged",
    "make-badges": "istanbul-badges-readme --logo=vitest --exitCode=1",
    "make-badges:ci": "npm run make-badges -- --ci",
    "test": "vitest --dir src",
    "test:cov": "prisma generate && vitest run --coverage",
    "test:e2e": "vitest --dir test"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.18.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/testing": "^11.1.27",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express-prom-bundle": "^8.0.0",
    "helmet": "^8.2.0",
    "nest-winston": "^1.10.2",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.6.0",
    "istanbul-badges-readme": "^1.9.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0",
    "vitest-sonar-reporter": "^3.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": "./node_modules/.bin/eslint --cache --fix"
  },
  "overrides": {
    "hono@<4.11.4": "4.11.4",
    "reflect-metadata": "^0.2.2"
  },
  "engines": {
    "node": "24.x"
  },
  "volta": {
    "node": "24.14.0"
  }
}
