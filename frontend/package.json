    "@types/node": "^24.13.2",
    "@vitejs/plugin-react": "^6.0.3",
    "axios": "^1.18.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "sass-embedded": "^1.100.0",
