    "lint": "eslint \"src/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\" --fix",
    "test:unit": "vitest --mode test",
    "test:cov": "vitest run --mode test --coverage",
    "build": "vite build"
  },
