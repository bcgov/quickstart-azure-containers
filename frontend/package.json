{
  "name": "quickstart-azure-containers-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "clean": "rimraf ./node_modules/.vite",
    "build:analyze": "vite build --mode analyze",
    "build:clean": "rimraf dist",
